		{"id":"analyse","type":"text","text":"🔍 **Analyse & Classification**\n──────────────────────\n• Identifier le sujet du commentaire\n• Catégoriser : bug / feature / amélioration\n• Évaluer l'impact sur le système","x":-2480,"y":-1360,"width":340,"height":180,"color":"4"},
